# ═══════════════════════════════════════════════════════════
# RETROWORKS HR — Environment Variables
# Copy to .env.local and fill in values
# NEVER commit .env.local or .env to git
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NODE_ENV=development
APP_NAME="RetroWorks HR"
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────
# DATABASE (PostgreSQL + pgvector)
# ─────────────────────────────────────────────
DATABASE_URL=postgresql://retroworks:retroworks@localhost:5432/retroworks_hr

# ─────────────────────────────────────────────
# REDIS (Upstash URL format also supported)
# ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# ─────────────────────────────────────────────
# JWT
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────
JWT_SECRET=CHANGE-ME-generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE-ME-different-from-jwt-secret
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# MAGIC LINKS
# ─────────────────────────────────────────────
MAGIC_LINK_SECRET=CHANGE-ME-magic-link-secret
MAGIC_LINK_EXPIRES_MINUTES=15

# ─────────────────────────────────────────────
# PII ENCRYPTION
# Generate with: openssl rand -hex 32
# ─────────────────────────────────────────────
ENCRYPTION_KEY=CHANGE-ME-32-byte-hex-key-for-aes-256
USE_KMS=false  # Set true in production with AWS KMS

# ─────────────────────────────────────────────
# OIDC / SSO (Keycloak dev)
# ─────────────────────────────────────────────
OIDC_ISSUER_URL=http://localhost:8080/realms/retroworks
OIDC_CLIENT_ID=retroworks-hr
OIDC_CLIENT_SECRET=retroworks-secret

# ─────────────────────────────────────────────
# AWS (use LocalStack / MinIO for local dev)
# ─────────────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_S3_BUCKET=retroworks-hr-local
AWS_S3_ENDPOINT=http://localhost:9000  # MinIO local; remove in production
AWS_KMS_KEY_ID=                         # Required in production
AWS_SES_FROM_EMAIL=noreply@retroworks.hr
AWS_CLOUDFRONT_URL=

# ─────────────────────────────────────────────
# WEBHOOKS
# ─────────────────────────────────────────────
WEBHOOK_SECRET=CHANGE-ME-webhook-hmac-secret

# ─────────────────────────────────────────────
# AI / RAG
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=512
CHUNK_OVERLAP=64
VECTOR_DIMENSIONS=1536
MAX_CONTEXT_DOCS=5
CONFIDENCE_THRESHOLD=0.7

# ─────────────────────────────────────────────
# NEXT.JS (Web)
# ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_DOMAIN=localhost
NEXT_PUBLIC_CLOUDFRONT_DOMAIN=
NEXT_PUBLIC_OIDC_URL=http://localhost:8080
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE-ME-nextauth-secret

# ─────────────────────────────────────────────
# SMTP (dev: MailHog, prod: SES)
# ─────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=RetroWorks HR <noreply@retroworks.hr>

# ─────────────────────────────────────────────
# METRICS
# ─────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PATH=/metrics
